# =============================================================================
# DocumentDB Cluster Configuration for Pix Service
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
name        = "pix-docdb"
environment = "<environment>"

# -----------------------------------------------------------------------------
# Cluster Configuration
# -----------------------------------------------------------------------------
instance_class  = "db.r6g.xlarge"
instances_count = 2

# -----------------------------------------------------------------------------
# Credentials (Secrets Manager will store the password)
# -----------------------------------------------------------------------------
master_username = "masteruser"

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
backup_retention_period = 7
preferred_backup_window = "07:00-09:00"

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
vpc_name = "<vpc-name>"

# -----------------------------------------------------------------------------
# DocumentDB TLS Configuration
# -----------------------------------------------------------------------------
# Set to "enabled" for production environments
documentdb_tls = "disabled"

# -----------------------------------------------------------------------------
# Additional Tags
# -----------------------------------------------------------------------------
additional_tags = {
  "ManagedBy"   = "terraform"
  "Project"     = "pix"
  "Owner"       = "<owner>"
  "Environment" = "<environment>"
}