# =============================================================================
# Valkey (ElastiCache) Configuration for Fetcher Service
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
name        = "fetcher-valkey"
environment = "<environment>"
vpc_name    = "<vpc-name>"

# -----------------------------------------------------------------------------
# Valkey Configuration
# -----------------------------------------------------------------------------
node_type              = "cache.m7g.large"
engine_version         = "7.2"
parameter_group_family = "valkey7"

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------
maintenance_window = "mon:00:00-mon:03:00"
apply_immediately  = false

# -----------------------------------------------------------------------------
# Parameters
# -----------------------------------------------------------------------------
parameters = [
  {
    name  = "latency-tracking"
    value = "yes"
  }
]

# -----------------------------------------------------------------------------
# DNS Configuration
# -----------------------------------------------------------------------------
dns_name      = "fetcher-valkey"
dns_zone_name = "<dns-zone-name>"

# -----------------------------------------------------------------------------
# Encryption Configuration
# -----------------------------------------------------------------------------
transit_encryption_enabled = true
transit_encryption_mode    = "preferred"

# -----------------------------------------------------------------------------
# Additional Tags
# -----------------------------------------------------------------------------
additional_tags = {
  "ManagedBy"   = "terraform"
  "Project"     = "fetcher"
  "Owner"       = "<owner>"
  "Environment" = "<environment>"
}